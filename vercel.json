{
  "outputDirectory": ".",
  "functions": {
    "api/contact.js": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    { "source": "/api/contact", "destination": "/api/contact.js" }
  ],
  "headers": [
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/dist/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}